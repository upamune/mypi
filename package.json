{
  "name": "@upamune/mypi",
  "version": "0.1.0",
  "description": "Personal Pi coding agent setup for upamune, including bundled mitsupi extensions.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "bin": {
    "mypi": "bin/mypi.mjs"
  },
  "files": [
    "bin",
    "extensions",
    "prompts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "doctor": "node bin/mypi.mjs doctor",
    "list": "node bin/mypi.mjs list",
    "status": "node bin/mypi.mjs status",
    "install:local-source": "node bin/mypi.mjs install --self-source .",
    "sync:goal": "node scripts/sync-goal.mjs",
    "setup": "node bin/mypi.mjs install"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-coding-agent",
    "coding-agent"
  ],
  "pi": {
    "skills": [
      "skills"
    ],
    "prompts": [
      "prompts"
    ],
    "extensions": [
      "extensions",
      "node_modules/mitsupi/extensions"
    ]
  },
  "dependencies": {
    "diff": "^8.0.2",
    "mitsupi": "^1.6.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
